# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# Database
DB_NAME=database-name
DB_USER=user-name
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=3306

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=razorpay=key-here
RAZORPAY_KEY_SECRET=secret-key-here

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you-email-here
EMAIL_HOST_PASSWORD=app-password-here
DEFAULT_FROM_EMAIL=from-email-here
ADMIN_EMAIL=admin-email-here
